# Match neovim convention: 0 (rightmost number key) → end of line,
# $ (shift+4, left of center) → beginning of line
bindkey -M vicmd '0' end-of-line
bindkey -M vicmd '$' beginning-of-line
bindkey -M visual '0' end-of-line
bindkey -M visual '$' beginning-of-line
